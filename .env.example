# Backend runtime configuration (safe template; do not put real secrets in git)
# Runtime configuration template (safe template; do not put real secrets in git)

# MQTT defaults (used when settings table values are empty)
DEFAULT_MQTT_SERVER=
DEFAULT_MQTT_USERNAME=
DEFAULT_MQTT_PASSWORD=

# Optional announcement endpoint, requested once per day with app version and anonymous device ID, for example:
# TIEZ_ANNOUNCEMENT_PING_URL=https://example.com/api/v1/ping
TIEZ_ANNOUNCEMENT_PING_URL=

# Optional AI request referer header (for compatible providers)
AI_HTTP_REFERER=
